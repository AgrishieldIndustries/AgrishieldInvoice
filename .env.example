# API Settings
API_V1_STR=/api/v1
SECRET_KEY=replace-with-a-secure-random-32-byte-hex-string-for-production
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days in minutes

# Project Metadata
PROJECT_NAME=Agrishield Admin

# Database Configurations (Local SQLite Fallback)
# Leave database parameters default for SQLite or fill below for PostgreSQL (e.g. Supabase, Railway Postgres)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agrishield

# Explicit Database URL Connection String (Overrides individual parameters above)
# Format: postgresql://user:password@server:port/db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agrishield

# CORS Configuration
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:3000,https://agrishield.vercel.app
